    // ==========================================
    // CIVICRM TOKENS MODAL
    // ==========================================
    editor.Panels.addButton('options', {
      id: 'civicrm-tokens-btn',
      className: 'fa fa-address-book',
      command: 'open-civicrm-tokens',
      attributes: { title: 'Tokens CiviCRM' },
    });

    editor.Commands.add('open-civicrm-tokens', {
      run(editor, sender) {
        sender && sender.set('active', 0);
        const modal = editor.Modal;
        modal.setTitle('Tokens CiviCRM');
        
        const content = document.createElement('div');
        content.innerHTML = '<p>Chargement des tokens depuis CiviCRM...</p>';
        modal.setContent(content);
        modal.open();

        fetch('/s/grapesjs-custom/civicrm/tokens')
          .then(response => response.json())
          .then(data => {
            if (data.success && data.data && data.data.values) {
              const tokens = data.data.values;
              let html = '<p>Cliquez sur un token pour le copier dans le presse-papier, puis collez-le dans votre texte.</p>';
              html += '<div class="civicrm-token-list">';
              tokens.forEach((t: any) => {
                const tokenStr = '{' + t.name + '}';
                const label = t.label || t.title || t.name;
                html += `<div class="civicrm-token-item" title="Copier" onclick="navigator.clipboard.writeText('${tokenStr}'); alert('Copié : ${tokenStr}');"><strong>${label}</strong> : ${tokenStr}</div>`;
              });
              html += '</div>';
              content.innerHTML = html;
            } else {
              content.innerHTML = '<p style="color:red">Erreur lors du chargement des tokens. Vérifiez la clé API dans Mautic.</p>';
            }
          })
          .catch(err => {
            content.innerHTML = '<p style="color:red">Erreur réseau : impossible de joindre l&apos;API CiviCRM Mautic Proxy.</p>';
            console.error(err);
          });
      }
    });

  });
};

export default GrapesJsCustomPlugin;

if (!window.MauticGrapesJsPlugins) window.MauticGrapesJsPlugins = [];

window.MauticGrapesJsPlugins.push({
  name: 'GrapesJsCustomPlugin',
  plugin: GrapesJsCustomPlugin,
  context: ['page', 'email-mjml'],
  pluginOptions: { options: { test: true } },
});
<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-label="{{ 'civicrmbuilder.modal.close'|trans }}"><span aria-hidden="true">&times;</span></button>
    <h4 class="modal-title" id="CiviCrmLinkModalLabel">{{ 'civicrmbuilder.modal.link_template.title'|trans }}</h4>
</div>

<div class="modal-body">
    <p>{{ 'civicrmbuilder.modal.link_template.help'|trans }}</p>
    
    <div class="form-group">
        <label for="civicrm-template-search" class="control-label">{{ 'civicrmbuilder.modal.link_template.search_label'|trans }}</label>
        <div class="input-group">
            <span class="input-group-addon"><i class="fa fa-search"></i></span>
            <input type="text" id="civicrm-template-search" class="form-control" placeholder="{{ 'civicrmbuilder.modal.link_template.search_placeholder'|trans }}" autocomplete="off">
        </div>
    </div>

    <div id="civicrm-search-status" style="margin-bottom: 15px; color: #777;"></div>

    <form id="civicrm-link-form" action="{{ path('civicrm_builder_civicrm_link_template', {'objectId': objectId}) }}" method="POST" style="display:none;">
        <div class="form-group">
            <label class="control-label">{{ 'civicrmbuilder.modal.link_template.select_label'|trans }}</label>
            <div id="civicrm-search-results" style="max-height: 200px; overflow-y: auto; border: 1px solid #ccc; padding: 10px; border-radius: 4px;">
                <!-- Résultats insérés ici en JS -->
            </div>
        </div>
        <div class="text-center mt-md">
            <button type="submit" class="btn btn-primary btn-lg" id="civicrm-btn-submit" disabled><i class="fa fa-link"></i> {{ 'civicrmbuilder.modal.link_template.submit'|trans }}</button>
        </div>
    </form>
</div>

<script>
(function($) {
    const translations = {
        searching: {{ 'civicrmbuilder.modal.link_template.searching'|trans|json_encode|raw }},
        resultsFound: {{ 'civicrmbuilder.modal.link_template.results_found'|trans({'%count%': '__COUNT__'})|json_encode|raw }},
        noResults: {{ 'civicrmbuilder.modal.link_template.no_results'|trans({'%query%': '__QUERY__'})|json_encode|raw }},
        communicationError: {{ 'civicrmbuilder.modal.link_template.communication_error'|trans|json_encode|raw }},
        saving: {{ 'civicrmbuilder.modal.link_template.saving'|trans|json_encode|raw }},
        linkError: {{ 'civicrmbuilder.modal.link_template.link_error'|trans|json_encode|raw }},
        serverError: {{ 'civicrmbuilder.modal.link_template.server_error'|trans|json_encode|raw }},
        submit: {{ 'civicrmbuilder.modal.link_template.submit'|trans|json_encode|raw }}
    };

    let debounceTimer;
    
    $('#civicrm-template-search').on('input', function() {
        clearTimeout(debounceTimer);
        const query = $(this).val().trim();
        const $status = $('#civicrm-search-status');
        const $results = $('#civicrm-search-results');
        const $form = $('#civicrm-link-form');
        const $btn = $('#civicrm-btn-submit');

        if (query.length === 0) {
            $status.text('');
            $form.hide();
            return;
        }

        $status.html('<i class="fa fa-spinner fa-spin"></i> ' + translations.searching);
        $form.hide();
        $results.empty();
        $btn.prop('disabled', true);

        debounceTimer = setTimeout(function() {
            $.ajax({
                url: "{{ path('civicrm_builder_civicrm_search_template') }}",
                type: 'POST',
                data: { query: query },
                success: function(response) {
                    if (response.success && response.data && response.data.length > 0) {
                        $status.html('<span class="text-success"><i class="fa fa-check"></i> ' + translations.resultsFound.replace('__COUNT__', response.data.length) + '</span>');
                        $form.show();
                        
                        let html = '';
                        response.data.forEach(function(item) {
                            html += '<div class="radio"><label>';
                            html += '<input type="radio" name="civicrm_template_id" value="' + item.id + '" required>';
                            html += '<strong>[' + item.id + ']</strong> ' + item.msg_title;
                            html += '</label></div>';
                        });
                        $results.html(html);

                        // Activer le bouton si un choix est fait
                        $('input[name="civicrm_template_id"]').on('change', function() {
                            $btn.prop('disabled', false);
                        });

                        // Si c'est un chiffre (ID exact) et qu'il y a un seul résultat, le sélectionner par défaut
                        if (response.data.length === 1 && /^\d+$/.test(query)) {
                            $('input[name="civicrm_template_id"]').prop('checked', true).trigger('change');
                        }

                    } else {
                        $status.html('<span class="text-danger"><i class="fa fa-exclamation-triangle"></i> ' + translations.noResults.replace('__QUERY__', query) + '</span>');
                    }
                },
                error: function() {
                    $status.html('<span class="text-danger"><i class="fa fa-times"></i> ' + translations.communicationError + '</span>');
                }
            });
        }, 500); // 500ms debounce
    });

    // Handle form submission via AJAX to update Mautic properly
    $('#civicrm-link-form').on('submit', function(e) {
        e.preventDefault();
        const $btn = $('#civicrm-btn-submit');
        $btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> ' + translations.saving);

        $.ajax({
            url: $(this).attr('action'),
            type: 'POST',
            data: $(this).serialize(),
            success: function(response) {
                if (response.success) {
                    // Mautic function to close modal and show notification
                    if (typeof mauticAjaxAction !== 'undefined') {
                        // Trick to reload page or show flash
                        window.location.reload();
                    } else {
                        window.location.reload();
                    }
                } else {
                    alert(response.error || translations.linkError);
                    $btn.prop('disabled', false).html('<i class="fa fa-link"></i> ' + translations.submit);
                }
            },
            error: function() {
                alert(translations.serverError);
                $btn.prop('disabled', false).html('<i class="fa fa-link"></i> ' + translations.submit);
            }
        });
    });
})(jQuery);
</script>

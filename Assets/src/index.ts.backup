    const iconHeader = `
      <svg viewBox="0 0 24 24" width="32" height="32" aria-hidden="true">
        <path fill="currentColor" d="M3 5h18v5H3V5zm2 2v1h14V7H5zm-2 6h18v6H3v-6zm2 2v2h14v-2H5z"/>
      </svg>

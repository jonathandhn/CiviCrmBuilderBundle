{
  "name": "jonathandhn/civicrm-builder-bundle",
  "description": "CiviCRM Builder integration for Mautic",
  "license": "GPL-3.0-or-later",
  "type": "mautic-plugin",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "extra": {
    "install-directory-name": "CiviCrmBuilderBundle"
  },
  "autoload": {
    "psr-4": {
      "MauticPlugin\\CiviCrmBuilderBundle\\": ""
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MauticPlugin\\CiviCrmBuilderBundle\\Tests\\": "Tests"
    }
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.66"
  },
  "scripts": {
    "cs:fix": "php-cs-fixer fix --config=.php-cs-fixer.php --sequential",
    "cs:check": "php-cs-fixer fix --config=.php-cs-fixer.php --dry-run --diff --sequential"
  }
}
